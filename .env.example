# ─── Deployer ────────────────────────────────────────────────────────────────
PRIVATE_KEY=                          # deployer wallet private key (no 0x prefix)
SEPOLIA_RPC_URL=                      # Alchemy / Infura Sepolia endpoint
ETHERSCAN_API_KEY=                    # for contract verification

# ─── Deployed contract addresses (populated by scripts/deploy.ts) ─────────────
#
# LOCAL (hardhat node) — all contracts deployed from scratch.
# SEPOLIA              — MockUSDT is NOT deployed; Zama's official mock is used instead:
#
#   Zama mock USDT underlying : 0xa7dA08FafDC9097Cc0E7D4f113A61e31d7e8e9b0
#     └─ has a public mint(address, uint256) limited to 1,000,000 tokens per call
#   Zama cUSDTMock (reference) : 0x4E7B06D78965594eB5EF5414c357ca21E1554491
#     └─ NOT used — our MockcUSDT wraps the underlying above with our own FHE interface
#
# Source: https://docs.zama.org/protocol/protocol-apps/addresses/testnet/sepolia

MOCK_USDT_ADDRESS=                    # local: deployed | sepolia: 0xa7dA08FafDC9097Cc0E7D4f113A61e31d7e8e9b0
CUSDT_ADDRESS=                        # our MockcUSDT (deployed on both networks, wraps MOCK_USDT)
ROUND_FACTORY_ADDRESS=
ALLOCATIONS_ADDRESS=
SUBSCRIPTION_ADDRESS=
CEQUITY_ADDRESS=
DISCLOSURE_ADDRESS=

# ─── Frontend (Next.js) — auto-written by scripts/deploy.ts ──────────────────
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_MOCK_USDT_ADDRESS=
NEXT_PUBLIC_CUSDT_ADDRESS=
NEXT_PUBLIC_ROUND_FACTORY_ADDRESS=
NEXT_PUBLIC_ALLOCATIONS_ADDRESS=
NEXT_PUBLIC_SUBSCRIPTION_ADDRESS=
NEXT_PUBLIC_CEQUITY_ADDRESS=
NEXT_PUBLIC_DISCLOSURE_ADDRESS=
NEXT_PUBLIC_SEPOLIA_RPC_URL=          # optional: override the default public RPC
